{
  "name": "regexp-assemble-syntax",
  "displayName": "RegExp-Assemble Syntax",
  "description": "Syntax highlighting for RegExp-Assemble files",
  "version": "0.0.1",
  "repository": {
		"type": "git",
		"url": "https://github.com/coreruleset/regexp-assemble-syntax"
	},
  "publisher": "coreruleset",
  "engines": {
    "vscode": "^1.72.0",
    "node": ">=24 <25"
  },
  "scripts": {
    "test": "node ./test/runTest.js",
    "test:grammar": "node ./test/runTest.js grammar.test.js",
    "test:extension": "node ./test/runTest.js extension.test.js"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ra",
        "aliases": [
          "RegExp-Assemble",
          "ra"
        ],
        "extensions": [
          ".data",
          ".ra"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ra",
        "scopeName": "source.ra",
        "path": "./syntaxes/ra.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.0",
    "chai": "^4.5.0",
    "js-yaml": "^4.1.0",
    "mocha": "^11.7.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.2.1"
  }
}
